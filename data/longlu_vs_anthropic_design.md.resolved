### 6.7 AI 输出质量评估体系【新增】

```python
# quality_metrics.py

# 核心质量指标追踪（写入 SQLite quality_metrics 表）
QUALITY_METRICS = {
    "法律引用准确率": """
        # 引用法条是否存在且当前有效
        valid_citations / total_citations
    """,
    "律师修改率": """
        # 律师改稿 diff 中修改行数占总行数的比例
        attorney_edited_lines / total_lines
    """,
    "重大错误率": """
        # 🔴 标注项中被律师否定的比例（标注了但实际没问题 = 误报）
        red_flag_overturned / total_red_flags
    """,
    "阶段完成率": """
        # 案件成功从 Phase 1 推进到 Phase 4 的比例（衡量工作流稳定性）
        cases_reached_phase4 / total_cases
    """,
}

def track_attorney_edit(case_id: str, v1: str, v2: str, reason: str):
    """律师每次改稿后自动调用，写入质量数据"""
    edit_rate = compute_edit_rate(v1, v2)
    db.insert("quality_metrics", {
        "case_id": case_id,
        "metric": "attorney_edit_rate",
        "value": edit_rate,
        "reason_tags": extract_reason_tags(reason),  # 如："法律引用错误"/"措辞不当"等
        "timestamp": datetime.now(),
    })
```

