### 6.6 多客户数据隔离【新增】

```python
# isolation.py

# SQLite：所有表必须包含 client_id，查询强制过滤
def get_case(case_id: str, client_id: str) -> dict:
    # 禁止：SELECT * FROM cases WHERE case_id = ?
    # 必须：SELECT * FROM cases WHERE case_id = ? AND client_id = ?
    return db.query(
        "SELECT * FROM cases WHERE case_id = ? AND client_id = ?",
        (case_id, client_id)
    )

# Qdrant：每个客户使用独立 Collection
def get_client_collection(client_id: str) -> str:
    return f"legal_kb_{client_id}"  # 禁止跨 Collection 检索

# 文件系统：严格目录隔离
FILE_ROOT = Path("cases/{client_id}/{case_id}/")

# LLM 调用：禁止在同一 prompt 混入不同客户信息
def validate_prompt_isolation(prompt: str, client_id: str):
    other_clients = db.query("SELECT client_id FROM clients WHERE client_id != ?", (client_id,))
    for c in other_clients:
        if c["name"] in prompt:  # 简单检查：其他客户名称不应出现
            raise IsolationViolationError(f"Prompt 可能混入了其他客户信息")
```

