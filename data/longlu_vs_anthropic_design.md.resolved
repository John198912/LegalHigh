### 6.5 API 降级与限流策略【新增】

```python
# fallback_strategy.py
from tenacity import retry, stop_after_attempt, wait_exponential

MODEL_FALLBACK_CHAIN = [
    ("claude-3-5-sonnet-20241022", "Claude API"),   # 首选
    ("deepseek-r1-32b",           "本地 vLLM"),    # 降级1：API限流时
    ("qwen2.5-7b",                "本地 vLLM"),    # 降级2：32B不可用时
]

@retry(stop=stop_after_attempt(3), wait=wait_exponential(min=1, max=10))
def call_with_fallback(prompt: str, task_type: str) -> str:
    for model, label in MODEL_FALLBACK_CHAIN:
        try:
            result = call_model(model, prompt, timeout=30)
            if task_type == "large" and model != MODEL_FALLBACK_CHAIN[0][0]:
                # 降级时在输出中标注
                result += f"\n⚠️ 注意：本次分析使用降级模型（{label}），建议条件恢复后重新分析。"
            return result
        except (TimeoutError, RateLimitError):
            continue
    # 全部失败：保存任务到队列，通知律师
    enqueue_task(prompt, task_type)
    notify_attorney("系统临时不可用，分析任务已排队，预计 15 分钟后重试。")
    raise SystemUnavailableError
```

