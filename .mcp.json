{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-filesystem"],
      "description": "文件系统操作，支持 PDF/DOCX/JPG/PNG 读取和 OCR",
      "config": {
        "formats": ["pdf", "docx", "jpg", "png"],
        "ocr": true,
        "ocr_engine": "surya"
      }
    },
    "law-database": {
      "command": "placeholder",
      "args": [],
      "description": "【占位】中国法律法规数据库检索，接入北大法宝/威科先行/国家法律法规数据库",
      "config": {
        "sources": ["北大法宝", "威科先行", "国家法律法规数据库"],
        "search_types": ["keyword", "semantic", "article_number"],
        "note": "待接入实际 MCP Server 实现"
      }
    },
    "case-retrieval": {
      "command": "placeholder",
      "args": [],
      "description": "【占位】中国裁判文书网案例检索，支持语义+关键词混合搜索",
      "config": {
        "source": "中国裁判文书网",
        "search_type": "semantic+keyword",
        "filters": ["案由", "法院层级", "裁判年份", "地区"],
        "note": "待接入实际 MCP Server 实现"
      }
    },
    "enforcement-check": {
      "command": "placeholder",
      "args": [],
      "description": "【占位】中国执行信息公开网查询，支持失信被执行人和限消查询",
      "config": {
        "source": "中国执行信息公开网",
        "watch_types": ["失信被执行人", "限制高消费", "终本案件"],
        "note": "待接入实际 MCP Server 实现"
      }
    },
    "notification": {
      "command": "placeholder",
      "args": [],
      "description": "【占位】通知推送服务，支持企业微信和钉钉",
      "config": {
        "channels": ["企业微信", "钉钉"],
        "triggers": ["时效预警（到期前30天）", "审查请求", "案件状态变更"],
        "note": "待接入实际 Webhook 实现"
      }
    }
  }
}
